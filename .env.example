# ── Database (shared Postgres on dev server) ──
DATABASE_HOST=192.168.50.154
DATABASE_PORT=5432
DATABASE_USER=devuser
DATABASE_PASSWORD=
DATABASE_NAME=nexum_dev
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# ── Redis (shared Redis on dev server) ──
REDIS_HOST=192.168.50.154
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=nexum:
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ── Object Storage (shared MinIO on dev server, S3-compatible) ──
STORAGE_ENDPOINT=http://192.168.50.154:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=
STORAGE_BUCKET=nexum-dev
STORAGE_REGION=us-east-1

# ── Auth (Better Auth, self-hosted) ──
BETTER_AUTH_SECRET=change-me-in-development
BETTER_AUTH_URL=http://localhost:3000

# ── Email (MailHog for dev, SMTP2GO for production) ──
SMTP_HOST=192.168.50.154
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@nexum.com.au

# ── SMS (leave empty for dev console logging) ──
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=

# ── Application ──
NODE_ENV=development
API_PORT=3002
API_HOST=0.0.0.0
FRONTEND_URL=http://localhost:5174
API_URL=http://localhost:3002
LOG_LEVEL=debug
