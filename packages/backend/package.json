{
  "name": "@nexum/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run --testPathPattern='.*\\.test\\.ts$' --testPathIgnorePatterns='integration'",
    "test:integration": "vitest run --testPathPattern='.*\\.integration\\.test\\.ts$'",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:generate:tenant": "drizzle-kit generate --config drizzle-tenant.config.ts",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:public": "drizzle-kit migrate",
    "db:migrate:tenants": "tsx src/db/migrate-tenants.ts",
    "db:migrate:tenant": "tsx src/db/migrate-tenant.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:test": "tsx src/db/seed-test.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/websocket": "^11.2.0",
    "@nexum/pdf-templates": "workspace:*",
    "@nexum/shared": "workspace:*",
    "@scalar/api-reference": "^1.49.1",
    "jose": "^6.0.11",
    "bullmq": "^5.71.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.2",
    "fastify-type-provider-zod": "^6.1.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.0",
    "nodemailer": "^8.0.3",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "puppeteer": "^24.39.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^7.0.11",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
